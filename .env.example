# Copy to .env and fill in. Never commit .env.

# --- RAG (main app + ingest) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
# Advanced: ignore docs/rag_ingestion_log.json and pick embeddings from OPENAI_API_KEY only (debug).
# RAG_IGNORE_INGESTION_LOG=1

# Optional: embedding / chat fallbacks
GEMINI_API_KEY=
MISTRAL_API_KEY=

# --- Signal Scanner (family-office-signal-scanner) ---
# Uses ANTHROPIC_API_KEY and optional ANTHROPIC_MODEL from above.

# --- Enrichment pipelines (optional) ---
APOLLO_API_KEY=
HUNTER_API_KEY=
APIFY_API_TOKEN=
